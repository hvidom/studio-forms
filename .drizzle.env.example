# ─── Cloudflare D1 (used by drizzle.config.ts in production) ───────────────
# Get these from: Cloudflare Dashboard → My Profile → API Tokens
# and: Workers & Pages → your worker → D1 → your database
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_D1_DATABASE_your_database_id_here
CLOUDFLARE_D1_TOKEN=your_d1_api_token_here

# ─── Local dev (drizzle.config.ts non-prod path) ────────────────────────────
# Optional: override where the local SQLite file lives
# LOCAL_DB_PATH=file:./src/db/local.db
