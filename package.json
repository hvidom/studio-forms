{
  "name": "studio-forms",
  "version": "1.0.1",
  "private": true,
  "description": "My starter for Astro ShacnUI forms and CLoudflare D1 DB with Drizzle studio",
  "keywords": [
    "Shadcn",
    "Astro",
    "Bun",
    "Drizzle",
    "Cloudflare",
    "Forms",
    "D1",
    "Tailwindcss"
  ],
  "homepage": "https://github.com/hvidom/studio-forms#readme",
  "bugs": {
    "url": "https://github.com/hvidom/studio-forms/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hvidom/studio-forms.git"
  },
  "license": "MIT",
  "author": "Hryhorii Victorovich Ilin",
  "type": "module",
  "scripts": {
    "browserslist": "bunx update-browserslist-db@latest",
    "dev": "astro dev",
    "build": "astro check && astro build && bun run build:tailwind && bun run build:postcss",
    "sync": "astro sync",
    "build:tailwind": "bun x @tailwindcss/cli -i src/styles/global.css -o dist/global.css --minify",
    "build:postcss": "postcss dist/global.css -o dist/global.css",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "astro build && wrangler deploy",
    "cf-typegen": "bunx wrangler types",
    "login": "wrangler login",
    "db:push": "bun drizzle-kit push",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push:prod": "NODE_ENV=production bun drizzle-kit push",
    "db:generate:prod": "NODE_ENV=production bun drizzle-kit generate",
    "db:migrate:prod": "NODE_ENV=production drizzle-kit migrate",
    "studio": "bunx drizzle-kit studio --port 4984",
    "db:check": "bun drizzle-kit check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.5.0",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.1",
    "baseline-browser-mapping": "^2.10.29",
    "caniuse-lite": "^1.0.30001792",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.3",
    "@types/bun": "latest",
    "@types/node": "^25.7.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.14",
    "tsx": "^4.21.0",
    "wrangler": "^4.90.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
